<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ── Insurance Program Form View ───────────────────────────────── -->
    <record id="view_insurance_program_form" model="ir.ui.view">
        <field name="name">pharmacy.insurance.program.form</field>
        <field name="model">pharmacy.insurance.program</field>
        <field name="arch" type="xml">
            <form string="Insurance Program">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Program Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Program Details">
                            <field name="discount"/>
                            <field name="valid_until"/>
                        </group>
                        <group string="Status">
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Insurance Program List View ───────────────────────────────── -->
    <record id="view_insurance_program_list" model="ir.ui.view">
        <field name="name">pharmacy.insurance.program.list</field>
        <field name="model">pharmacy.insurance.program</field>
        <field name="arch" type="xml">
            <list string="Insurance Programs"
                  decoration-muted="active == False"
                  decoration-warning="valid_until and valid_until &lt; current_date">
                <field name="name"        string="Program Name"/>
                <field name="discount"    string="Discount (%)"/>
                <field name="valid_until" string="Valid Until"/>
                <field name="active"      string="Active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ── Insurance Program Search View ─────────────────────────────── -->
    <record id="view_insurance_program_search" model="ir.ui.view">
        <field name="name">pharmacy.insurance.program.search</field>
        <field name="model">pharmacy.insurance.program</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <separator/>
                <filter name="active"
                        string="Active"
                        domain="[('active', '=', True)]"/>
                <filter name="expired"
                        string="Expired"
                        domain="[('valid_until', '&lt;', context_today().strftime('%Y-%m-%d'))]"/>
            </search>
        </field>
    </record>

    <!-- ── Insurance Program Action ──────────────────────────────────── -->
    <record id="action_insurance_program" model="ir.actions.act_window">
        <field name="name">Insurance Programs</field>
        <field name="res_model">pharmacy.insurance.program</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first insurance program
            </p>
            <p>
                Add insurance programs to apply discounts
                automatically when a patient has coverage.
            </p>
        </field>
    </record>

    <!-- ── Inherit res.partner form — add insurance field ────────────── -->
    <record id="view_partner_insurance_inherit" model="ir.ui.view">
        <field name="name">res.partner.insurance.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="insurance_program_id"
                       string="Insurance Program"
                       domain="[('active', '=', True)]"
                       options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>

    <!-- ── Configuration Submenu ──────────────────────────────────────── -->
    <menuitem id="menu_pharmacy_configuration"
              name="Configuration"
              parent="menu_pharmacy_root"
              sequence="99"/>

    <menuitem id="menu_insurance_programs"
              name="Insurance Programs"
              parent="menu_pharmacy_configuration"
              action="action_insurance_program"
              sequence="10"/>

</odoo>