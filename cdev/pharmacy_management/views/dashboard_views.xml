<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Simple Expiry Dashboard Action -->
    <record id="action_dashboard_expiry" model="ir.actions.act_window">
        <field name="name">Medicine Expiry Dashboard</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('product_id.is_medicine', '=', True)]</field>
        <field name="context">{'search_default_expiry': 1}</field>
    </record>

    <menuitem id="menu_pharmacy_dashboard_action"
              name="Expiry Dashboard Overview"
              parent="menu_medicine_expiry"
              action="action_dashboard_expiry"
              sequence="10"/>
</odoo>
