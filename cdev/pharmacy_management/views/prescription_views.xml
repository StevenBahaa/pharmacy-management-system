<?xml version="1.0" encoding="UTF-8"?>
<odoo>

<record id='prescription_view_list' model='ir.ui.view'>
        <field name='name'>prescription.view.list</field>
        <field name='model'>prescription</field>
        <field name='arch' type='xml'>
            <list decoration-success="state == 'delivered'"
                    decoration-warning="state == 'confirmed'"
                    decoration-muted="state == 'draft'">
                <field name='name'/>
                <field name='patient_id'/>
                <field name='doctor_id'/>
                <field name='date'/>
                <field name='state' readonly="1"/>
                <field name='total_amount' readonly="1" optional="show"/>
            </list>
        </field>
    </record>

    <record id='prescription_view_form' model='ir.ui.view'>
        <field name='name'>prescription.view.form</field>
        <field name='model'>prescription</field>
        <field name='arch' type='xml'>
            <form string='Prescription' class='o_form_readonly'>
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            invisible="state != 'draft'"
                            class="btn-primary"/>

                    <button name="action_deliver" string="Deliver" type="object"
                            invisible="state != 'confirmed'"/>

                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,confirmed,delivered"/>
                </header>
                <sheet>
                    <div class="oe_title" style="display: flex; align-items: center; gap: 16px;">
                            <h1>
                                <field name="name"/>
                            </h1>
                    </div>

                    <group>
                        <!-- Left column: Personal Info -->
                         <group string="Personal Information">
                            <field name='patient_id'/>
                            <field name='doctor_id'/>
                         </group>

                        <!-- Right column: Medical Info -->
                        <group string="Medical Information">
                            <field name='date'/>
                            <field name='total_amount' readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name='prescription' string='Prescription'>
                            <field name='line_ids'>
                                <list editable="bottom">
                                    <field name='product_id'/>
                                    <field name='lot_id'/>
                                    <field name='quantity'/>
                                    <field name='price_unit' readonly="1"/>
                                    <field name='subtotal' readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            <chatter/>
            </form>
        </field>
    </record>

    <record id='action_prescription' model='ir.actions.act_window'>
        <field name='name'>Prescription</field>
        <field name='res_model'>prescription</field>
        <field name='view_mode'>list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first prescription
            </p>
        </field>
    </record>

    <menuitem id='menu_pharmacy_prescription'
            name='Prescriptions'
            parent="menu_pharmacy_root"
            action='action_prescription'
            sequence='10'/>
</odoo>