<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="prescription_view_list" model="ir.ui.view">
        <field name="name">prescription.view.list</field>
        <field name="model">prescription</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'delivered'"
                  decoration-warning="state == 'confirmed'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="date"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="state" widget="badge" 
                                decoration-success="state == 'delivered'"
                                decoration-warning="state == 'confirmed'"
                                decoration-muted="state == 'draft'"/>
                <field name="total_amount" sum="Total"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="prescription_view_form" model="ir.ui.view">
        <field name="name">prescription.view.form</field>
        <field name="model">prescription</field>
        <field name="arch" type="xml">
            <form string="Prescription">
                <header>
                    <button name="action_print_invoice" string="Create Invoice" type="object"
                        invisible="state not in ('confirmed' , 'delivered')" class="btn-primary"/>

                    <button name="action_confirm" string="Confirm" type="object"
                        invisible="state != 'draft'" class="btn-primary"
                        groups="pharmacy_management.group_pharmacy_pharmacist,pharmacy_management.group_pharmacy_manager"/>

                    <button name="action_deliver" string="Deliver" type="object"
                        invisible="state != 'confirmed'" class="btn-primary"
                        groups="pharmacy_management.group_pharmacy_cashier,pharmacy_management.group_pharmacy_pharmacist,pharmacy_management.group_pharmacy_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,delivered"/>
                </header>
                <sheet>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <label for="name" string="Prescription Reference"/>
                        <h1>
                            <field name="name"
                                placeholder="Will be generated on save"
                                readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Personal Information">
                            <field name="is_cashier_only" invisible="1"/>
                            <field name="patient_id" required="1" readonly="state != 'draft' or is_cashier_only"/>
                            <field name="doctor_id" readonly="state != 'draft' or is_cashier_only"/>
                        </group>
                        <group string="Medical Information">
                        <field name="date" readonly="state != 'draft' or is_cashier_only"/>
                            <field name="total_amount" readonly="1"/>
                        </group>
                        <group string="Financial Information">
                            <field name="insurance_program_id" readonly="1"/>
                            <field name="discount"             readonly="1"/>
                            <field name="total_amount"         readonly="1"/>
                            <field name="amount_discount"      readonly="1"/>
                            <field name="total_after_discount" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="lines" string="Medicine Lines">
                        <field name="line_ids" readonly="state != 'draft' or is_cashier_only">
                                <list editable="bottom">
                                    <field name="product_id" required="1"/>
                                    <field name="lot_id" domain="[('product_id.product_tmpl_id', '=', product_id)]"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"  readonly="1"/>
                                    <field name="discount"    readonly="1"/>
                                    <field name="subtotal"    readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_prescription" model="ir.actions.act_window">
        <field name="name">Prescriptions</field>
        <field name="res_model">prescription</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first prescription
            </p>
        </field>
    </record>

    <record id="view_prescription_search" model="ir.ui.view">
        <field name="name">prescription.view.search</field>
        <field name="model">prescription</field>
        <field name="arch" type="xml">
            <search string="Search Prescriptions">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Patient" name="group_patient" context="{'group_by':'patient_id'}"/>
                    <filter string="Doctor" name="group_doctor" context="{'group_by':'doctor_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Active" name="active_records" domain="[('active', '=', True)]"/>
                    <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                </group>
            </search>
        </field>
    </record>
</odoo>