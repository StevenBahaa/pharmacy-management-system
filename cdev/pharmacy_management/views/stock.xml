<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Action — shows expired lots only -->
    <record id="action_expired_medicine_lots" model="ir.actions.act_window">
        <field name="name">Expired Medicines</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('product_id.is_medicine', '=', True),
            ('is_expired', '=', True)
        ]</field>
        <field name="context">{'search_default_filter_expired': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No expired medicines found.
            </p>
        </field>
    </record>

    <!-- List View — shows only product name and lot name -->
    <record id="view_expired_medicine_lots_list" model="ir.ui.view">
        <field name="name">stock.lot.expired.list</field>
        <field name="model">stock.lot</field>
        <field name="arch" type="xml">
            <list string="Expired Medicine Lots"
                decoration-danger="is_expired == True"
                create="false"
                delete="false">
                <field name="product_id" string="Medicine"/>
                <field name="name" string="Lot / Batch"/>
                <field name="expiration_date" string="Expired On"/>
                <field name="is_expired" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Menu item -->
    <menuitem id="menu_expired_medicines"
            name="Expired Medicines"
            parent="menu_pharmacy_root"
            action="action_expired_medicine_lots"
            sequence="30"/>
</odoo>