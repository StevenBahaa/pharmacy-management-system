<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_medicine_form" model="ir.ui.view">
        <field name="name">medicine.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-block">
                    <field name="is_medicine"/>
                    <label for="is_medicine"/>
                </span>
            </xpath>
            <xpath expr="//page[@name='general_information']" position="after">
                <page name="pharmaceutical_info" string="Pharmaceutical Info" invisible="not is_medicine">
                    <group>
                        <group string="Identification">
                            <field name="medicine_category_id" domain="[('parent_id.name', '=', 'Medicine')]"/>
                            <field name="inn_name"/>
                            <field name="brand_name"/>
                            <field name="atc_code"/>
                        </group>
                        <group string="Form &amp; Administration">
                            <field name="dosage_form"/>
                            <field name="strength"/>
                            <field name="route_of_administration"/>
                            <field name="x_requires_prescription"/>
                        </group>
                        <group string="Regulatory &amp; Tracking">
                            <field name="prescription_status"/>
                            <field name="is_controlled_substance" invisible="1"/>
                            <field name="requires_double_check"/>
                            <field name="registration_authority"/>
                            <field name="registration_number"/>
                        </group>
                        <group string="Manufacturing &amp; Storage">
                            <field name="manufacturer_name"/>
                            <field name="manufacturer_country"/>
                            <field name="storage_condition"/>
                            <field name="shelf_life_months"/>
                            <field name="x_min_stock_qty"/>
                        </group>
                    </group>
                    <group string="Ingredients">
                        <field name="active_ingredient"/>
                        <field name="excipients"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_product_list_inherit_medicine" model="ir.ui.view">
        <field name="name">product.template.list.inherit.medicine</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="decoration-danger">
                    is_medicine and qty_available &lt; x_min_stock_qty
                </attribute>
            </xpath>
        </field>
    </record>

    <record id="view_product_search_inherit_medicine" model="ir.ui.view">
        <field name="name">product.template.search.inherit.medicine</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">

            <xpath expr="//search" position="inside">

                <filter name="low_stock"
                    string="Low Stock"
                    domain="[('x_is_low_stock', '=', True)]"/>

                    <filter name="requires_prescription"
                        string="Requires Prescription"
                        domain="[('x_requires_prescription', '=', True)]"/>

                    <group expand="0" string="Group By">
                        <filter name="group_by_medicine_category"
                                string="Medicine Category"
                                context="{'group_by': 'medicine_category_id'}"/>
                    </group>

            </xpath>
        </field>
    </record>

    <record id="view_pharmacy_medicine_list_inherit" model="ir.ui.view">
        <field name="name">pharmacy.medicine.list.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">

                    <!-- Hide unwanted default columns -->
        <xpath expr="//list/field[@name='default_code']" position="attributes">
            <attribute name="optional">hide</attribute>
        </xpath>

        <xpath expr="//list/field[@name='product_tag_ids']" position="attributes">
            <attribute name="optional">hide</attribute>
        </xpath>

        <xpath expr="//list/field[@name='standard_price']" position="attributes">
            <attribute name="optional">hide</attribute>
        </xpath>

        <xpath expr="//list/field[@name='qty_available']" position="attributes">
            <attribute name="optional">hide</attribute>
        </xpath>

        <xpath expr="//list/field[@name='virtual_available']" position="attributes">
            <attribute name="optional">hide</attribute>
        </xpath>

            <xpath expr="//list/field[@name='name']" position="after">
                <field name="qty_available"
                    string="Current Stock"
                    optional="show"/>
                <field name="x_min_stock_qty"
                    string="Minimum Stock"
                    optional="show"/>
                <field name="x_requires_prescription"
                    string="Requires Prescription"
                    optional="show"
                    widget="boolean_toggle"/>

            </xpath>

        </field>
    </record>

    <record id="action_pharmacy_medicine" model="ir.actions.act_window">
        <field name="name">Medicines</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('is_medicine', '=', True)]</field>
        <field name="context">{'default_is_medicine': True}</field>
    </record>

</odoo>
